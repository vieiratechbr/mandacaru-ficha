{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/registro/layout,_N_T_/auth/registro/page,_N_T_/auth/registro"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/registro/__PAGE__",
    "/auth/registro",
    "/auth",
    "/_index",
    "/_head"
  ]
}